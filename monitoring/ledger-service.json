{
  "annotations": { "list": [] },
  "description": "Ledger service — Constitution Principle IV. Counters: ledger.created/updated/deleted/archived/audit.purged. Histogram: ledger.operation.duration (explicit buckets [10ms, 25ms, 50ms, 100ms, 250ms, 500ms, 1s, 2.5s, 5s, 10s] from research.md §10). FusionCache hit/miss panels. /health/ready up panel. Same JSON loads in the local Aspire dashboard's Dashboards view and production Grafana.",
  "editable": true,
  "graphTooltip": 0,
  "id": null,
  "panels": [
    {
      "type": "row",
      "id": 100,
      "title": "Ledger CRUD counters (per-RPC outcomes)",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
      "collapsed": false,
      "panels": []
    },
    {
      "type": "stat",
      "id": 1,
      "title": "Created (rate, 5m)",
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "gridPos": { "h": 6, "w": 4, "x": 0, "y": 1 },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "graphMode": "area" },
      "fieldConfig": { "defaults": { "unit": "ops" }, "overrides": [] },
      "targets": [
        { "refId": "A", "expr": "sum(rate(ledger_created_total{service_name=\"ledger-service\"}[5m]))" }
      ]
    },
    {
      "type": "stat",
      "id": 2,
      "title": "Updated (rate, 5m)",
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "gridPos": { "h": 6, "w": 4, "x": 4, "y": 1 },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "graphMode": "area" },
      "fieldConfig": { "defaults": { "unit": "ops" }, "overrides": [] },
      "targets": [
        { "refId": "A", "expr": "sum(rate(ledger_updated_total{service_name=\"ledger-service\"}[5m]))" }
      ]
    },
    {
      "type": "stat",
      "id": 3,
      "title": "Deleted (rate, 5m)",
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "gridPos": { "h": 6, "w": 4, "x": 8, "y": 1 },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "graphMode": "area" },
      "fieldConfig": { "defaults": { "unit": "ops" }, "overrides": [] },
      "targets": [
        { "refId": "A", "expr": "sum(rate(ledger_deleted_total{service_name=\"ledger-service\"}[5m]))" }
      ]
    },
    {
      "type": "stat",
      "id": 4,
      "title": "Archived (rate, 5m)",
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "gridPos": { "h": 6, "w": 4, "x": 12, "y": 1 },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "graphMode": "area" },
      "fieldConfig": { "defaults": { "unit": "ops" }, "overrides": [] },
      "targets": [
        { "refId": "A", "expr": "sum(rate(ledger_archived_total{service_name=\"ledger-service\"}[5m]))" }
      ]
    },
    {
      "type": "stat",
      "id": 5,
      "title": "Audit purged (1h)",
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "gridPos": { "h": 6, "w": 8, "x": 16, "y": 1 },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "graphMode": "area" },
      "fieldConfig": { "defaults": { "unit": "short" }, "overrides": [] },
      "targets": [
        { "refId": "A", "expr": "sum(increase(ledger_audit_purged_total{service_name=\"ledger-service\"}[1h]))" }
      ]
    },
    {
      "type": "row",
      "id": 101,
      "title": "Operation duration (SC-002 / SC-003 budgets)",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 7 },
      "collapsed": false,
      "panels": []
    },
    {
      "type": "timeseries",
      "id": 6,
      "title": "ledger.operation.duration P50 (per operation)",
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 8 },
      "fieldConfig": { "defaults": { "unit": "s" }, "overrides": [] },
      "targets": [
        {
          "refId": "A",
          "expr": "histogram_quantile(0.50, sum by (le, operation) (rate(ledger_operation_duration_seconds_bucket{service_name=\"ledger-service\"}[5m])))",
          "legendFormat": "{{operation}}"
        }
      ]
    },
    {
      "type": "timeseries",
      "id": 7,
      "title": "ledger.operation.duration P95 (per operation)",
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 8 },
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "red", "value": 1.0 }
            ]
          }
        },
        "overrides": []
      },
      "targets": [
        {
          "refId": "A",
          "expr": "histogram_quantile(0.95, sum by (le, operation) (rate(ledger_operation_duration_seconds_bucket{service_name=\"ledger-service\"}[5m])))",
          "legendFormat": "{{operation}}"
        }
      ]
    },
    {
      "type": "timeseries",
      "id": 8,
      "title": "ledger.operation.duration P99 (per operation)",
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 8 },
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "red", "value": 1.0 }
            ]
          }
        },
        "overrides": []
      },
      "targets": [
        {
          "refId": "A",
          "expr": "histogram_quantile(0.99, sum by (le, operation) (rate(ledger_operation_duration_seconds_bucket{service_name=\"ledger-service\"}[5m])))",
          "legendFormat": "{{operation}}"
        }
      ]
    },
    {
      "type": "row",
      "id": 102,
      "title": "FusionCache (L1 + L2 over Redis)",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 16 },
      "collapsed": false,
      "panels": []
    },
    {
      "type": "timeseries",
      "id": 9,
      "title": "FusionCache hit ratio",
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 17 },
      "fieldConfig": { "defaults": { "unit": "percentunit" }, "overrides": [] },
      "targets": [
        {
          "refId": "A",
          "expr": "sum(rate(fusioncache_cache_hit_total{service_name=\"ledger-service\"}[5m])) / clamp_min(sum(rate(fusioncache_cache_hit_total{service_name=\"ledger-service\"}[5m])) + sum(rate(fusioncache_cache_miss_total{service_name=\"ledger-service\"}[5m])), 1)",
          "legendFormat": "hit ratio"
        }
      ]
    },
    {
      "type": "timeseries",
      "id": 10,
      "title": "FusionCache hits vs misses (rate)",
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 17 },
      "fieldConfig": { "defaults": { "unit": "ops" }, "overrides": [] },
      "targets": [
        {
          "refId": "A",
          "expr": "sum(rate(fusioncache_cache_hit_total{service_name=\"ledger-service\"}[5m]))",
          "legendFormat": "hits"
        },
        {
          "refId": "B",
          "expr": "sum(rate(fusioncache_cache_miss_total{service_name=\"ledger-service\"}[5m]))",
          "legendFormat": "misses"
        }
      ]
    },
    {
      "type": "row",
      "id": 103,
      "title": "Health",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 25 },
      "collapsed": false,
      "panels": []
    },
    {
      "type": "stat",
      "id": 11,
      "title": "/health/ready (1=up, 0=down)",
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "gridPos": { "h": 6, "w": 24, "x": 0, "y": 26 },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "background",
        "graphMode": "area"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "green", "value": 1 }
            ]
          },
          "mappings": [
            { "type": "value", "options": { "0": { "text": "DOWN" }, "1": { "text": "UP" } } }
          ]
        },
        "overrides": []
      },
      "targets": [
        {
          "refId": "A",
          "expr": "max(probe_success{job=\"ledger-service\",probe=\"ready\"}) or max(up{job=\"ledger-service\"})"
        }
      ]
    }
  ],
  "refresh": "30s",
  "schemaVersion": 39,
  "tags": ["ledger-service", "constitution-principle-iv"],
  "templating": {
    "list": [
      {
        "name": "DS_PROMETHEUS",
        "label": "Prometheus",
        "type": "datasource",
        "query": "prometheus",
        "current": {},
        "hide": 0
      }
    ]
  },
  "time": { "from": "now-6h", "to": "now" },
